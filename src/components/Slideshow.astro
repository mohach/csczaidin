---
export interface Props {
  images: string[];
  alt?: string;
  id?: string;
}

const { images, alt = "Imagen del proyecto", id } = Astro.props;
const uid = id || `ss-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="slideshow" id={uid} data-ss>
  <div class="slideshow-track">
    {images.map((img, i) => (
      <div class="slide" data-index={i}>
        <img src={img} alt={`${alt} ${i + 1}`} loading={i === 0 ? "eager" : "lazy"} />
      </div>
    ))}
  </div>

  {images.length > 1 && (
    <>
      <button class="ss-prev" aria-label="Anterior">‹</button>
      <button class="ss-next" aria-label="Siguiente">›</button>
      <div class="ss-dots">
        {images.map((_, i) => (
          <button class="ss-dot" data-index={i} aria-label={`Ir a imagen ${i + 1}`}></button>
        ))}
      </div>
    </>
  )}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var all = document.querySelectorAll('[data-ss]');
    all.forEach(function(el) {
      var track = el.querySelector('.slideshow-track');
      var slides = el.querySelectorAll('.slide');
      var prev = el.querySelector('.ss-prev');
      var next = el.querySelector('.ss-next');
      var dots = el.querySelectorAll('.ss-dot');
      if (!track || slides.length === 0) return;
      var current = 0;
      var timer = null;

      function goTo(idx) {
        if (idx < 0) idx = slides.length - 1;
        if (idx >= slides.length) idx = 0;
        current = idx;
        track.style.transform = 'translateX(-' + (current * 100) + '%)';
        dots.forEach(function(d) { d.classList.remove('active'); });
        var active = el.querySelector('.ss-dot[data-index="' + current + '"]');
        if (active) active.classList.add('active');
      }

      function start() { stop(); timer = setInterval(function() { goTo(current + 1); }, 4000); }
      function stop() { if (timer) { clearInterval(timer); timer = null; } }

      if (prev) prev.addEventListener('click', function() { stop(); goTo(current - 1); start(); });
      if (next) next.addEventListener('click', function() { stop(); goTo(current + 1); start(); });
      dots.forEach(function(dot) {
        dot.addEventListener('click', function() {
          stop();
          goTo(parseInt(this.getAttribute('data-index')));
          start();
        });
      });

      // Touch swipe
      var startX = 0;
      track.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; stop(); }, {passive: true});
      track.addEventListener('touchend', function(e) {
        var diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) goTo(diff > 0 ? current + 1 : current - 1);
        start();
      }, {passive: true});

      goTo(0);
      if (slides.length > 1) start();
    });
  });
</script>

<style is:global>
  .slideshow {
    position: relative;
    width: 100%;
    max-width: 700px;
    margin: 1.5rem auto;
    overflow: hidden;
    border-radius: var(--r);
    box-shadow: var(--shadow-md);
    aspect-ratio: 16 / 10;
    background: var(--g100);
  }
  .slideshow-track {
    display: flex;
    transition: transform 0.5s ease;
    height: 100%;
  }
  .slide {
    min-width: 100%;
    height: 100%;
  }
  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ss-prev, .ss-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0,0,0,0.4);
    color: #fff;
    border: none;
    width: 36px;
    height: 36px;
    font-size: 1.5rem;
    cursor: pointer;
    z-index: 5;
    border-radius: 50%;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .ss-prev:hover, .ss-next:hover { background: rgba(0,0,0,0.7); }
  .ss-prev { left: 8px; }
  .ss-next { right: 8px; }

  .ss-dots {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 5;
  }
  .ss-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid #fff;
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }
  .ss-dot.active { background: #fff; }
</style>
