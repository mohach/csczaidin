</Layout>

<style is:global>
  .mem-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .mem-card {
    display: block;
    background: var(--w);
    border: 1px solid var(--g200);
    border-radius: var(--r);
    overflow: hidden;
    text-decoration: none !important;
    box-shadow: var(--shadow);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .mem-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    border-color: var(--green-light);
  }
  .mem-img {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: var(--g100);
  }
  .mem-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .mem-img-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: var(--g300);
    background: var(--g50);
  }
  .mem-body {
    padding: 0.85rem 1rem;
  }
  .mem-body h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--green);
    margin: 0 0 0.3rem;
  }
  .mem-body p {
    font-size: 0.85rem;
    color: var(--g500);
    margin: 0;
    line-height: 1.4;
  }

  @media (min-width: 640px) {
    .mem-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .mem-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
