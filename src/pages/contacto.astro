---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto" description="Ponte en contacto con el Centro Sociocultural Zaidín en Granada. Dirección, teléfono, email y mapa de situación.">
  <section class="page-hero">
    <h1>Contacto</h1>
    <p class="subtitle">Estamos aquí para escucharte y atenderte</p>
  </section>

  <section class="page-content-wide">
    <div class="contact-grid">
      <div class="card contact-card">
        <span class="contact-icon">📍</span>
        <h2>Dirección</h2>
        <p>
          Calle Zurbarán nº 8<br />
          C.P. 18007, Granada<br />
          Barrio del Zaidín
        </p>
        <a href="https://maps.app.goo.gl/K6dNXKctRxh8a5SF8" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          Abrir en Google Maps
        </a>
      </div>

      <div class="card contact-card">
        <span class="contact-icon">📱</span>
        <h2>Teléfono</h2>
        <p>
          <strong>WhatsApp:</strong><br />
          <a href="https://wa.me/34655120590" class="contact-link">655 12 05 90</a>
        </p>
        <p>
          <strong>Fijo:</strong><br />
          <a href="tel:958136876" class="contact-link">958 136 876</a>
        </p>
      </div>

      <div class="card contact-card">
        <span class="contact-icon">✉️</span>
        <h2>Email</h2>
        <p>
          <a href="mailto:csazaidin@yahoo.es" class="contact-link">csazaidin@yahoo.es</a>
        </p>
      </div>

      <div class="card contact-card">
        <span class="contact-icon">🌐</span>
        <h2>Redes Sociales</h2>
        <p>Síguenos en nuestras redes para estar al día de nuestras actividades:</p>
        <div class="social-links">
          <a href="https://www.instagram.com/csc_zaidin/" target="_blank" rel="noopener noreferrer" class="btn btn-social">
            Instagram
          </a>
          <a href="https://www.facebook.com/csczaidin" target="_blank" rel="noopener noreferrer" class="btn btn-social">
            Facebook
          </a>
        </div>
      </div>
    </div>

    <div class="map-section">
      <h2 class="map-title">Cómo llegar</h2>
      <div class="map-container">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3178.793965223222!2d-3.603996284608774!3d37.15330497970922!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd71fb5e20dc9381%3A0x7ca58a15c2928e57!2sC.%20Zurbar%C3%A1n%2C%208%2C%20Zaid%C3%ADn%2C%2018007%20Granada!5e0!3m2!1ses!2ses!4v1"
          width="100%" height="400"
          style="border:0; border-radius: 12px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa de situación del Centro Sociocultural Zaidín"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.25rem;
  }

  .contact-card {
    text-align: center;
    padding: 1.75rem 1.25rem;
  }

  .contact-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .contact-card h2 {
    margin-top: 0 !important;
    color: var(--primary);
    font-size: 1.15rem;
    margin-bottom: 0.75rem;
  }

  .contact-card p {
    margin-bottom: 0.75rem;
    font-size: 1rem;
    line-height: 1.6;
  }

  .contact-link {
    color: var(--accent);
    font-weight: 600;
    font-size: 1.05rem;
  }
  .contact-link:hover {
    color: var(--accent-dark);
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    text-decoration: none;
    transition: background 200ms ease, transform 200ms ease;
  }
  .btn:hover {
    transform: translateY(-1px);
    text-decoration: none;
  }

  .btn-primary {
    background: var(--primary);
    color: white;
  }
  .btn-primary:hover {
    background: var(--primary-dark);
    color: white;
  }

  .btn-social {
    background: #fef5ed;
    color: var(--accent-dark);
  }
  .btn-social:hover {
    background: var(--accent);
    color: white;
  }

  .map-section {
    margin: 3rem auto 1rem;
    max-width: 720px;
  }

  .map-title {
    text-align: center;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 1rem;
  }

  .map-container {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  }

  .map-container iframe {
    display: block;
  }
</style>
