</Layout>

<style is:global>
  .container { max-width: var(--max-w); margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 3.5rem 0; }
  .section-gray { background: var(--gray-50); }
  .section-title {
    font-size: 1.5rem; font-weight: 800;
    text-align: center; margin-bottom: 1.5rem;
  }
  .section-subtitle { text-align: center; margin-bottom: 2rem; font-size: 1rem; }

  /* Hero */
  .hero {
    padding: 5rem 1.25rem;
    background: linear-gradient(135deg, var(--primary-dark), var(--primary));
    text-align: center;
    color: white;
  }
  .hero-inner { max-width: 640px; margin: 0 auto; }
  .hero h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; line-height: 1.1; margin-bottom: 0.5rem; }
  .hero-tagline { font-size: clamp(0.9rem, 1.8vw, 1.1rem); letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.8; margin-bottom: 2rem; }
  .hero-quote {
    font-style: italic; font-size: clamp(0.9rem, 1.4vw, 1.05rem);
    line-height: 1.7; padding: 1.25rem 1.5rem;
    border-left: 3px solid #fbbf24;
    background: rgba(0,0,0,0.12); border-radius: 0 var(--radius) var(--radius) 0;
    margin-bottom: 2rem; text-align: left;
  }
  .hero-quote cite { display: block; margin-top: 0.4rem; font-style: normal; font-weight: 600; color: #fbbf24; }
  .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-hero {
    padding: 0.7rem 1.8rem; background: white; color: var(--primary);
    border-radius: 999px; font-weight: 700;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15); text-decoration: none;
  }
  .btn-hero:hover { color: var(--primary-dark); transform: translateY(-2px); }
  .btn-hero-outline {
    padding: 0.7rem 1.8rem; background: transparent; color: white;
    border: 2px solid rgba(255,255,255,0.5); border-radius: 999px; font-weight: 600; text-decoration: none;
  }
  .btn-hero-outline:hover { background: rgba(255,255,255,0.1); border-color: white; color: white; }

  /* Intro */
  .intro-text { max-width: 640px; margin: 0 auto; text-align: center; }
  .intro-text h2 { font-size: 1.4rem; margin-bottom: 1rem; }
  .intro-text p { color: var(--gray-500); margin-bottom: 0.8rem; }
  .intro-links { margin-top: 1.5rem; display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  /* Projects */
  .project-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); gap: 1rem; }
  .project-card {
    background: var(--white); border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg); padding: 1.5rem;
    box-shadow: var(--shadow);
    transition: box-shadow var(--transition), transform var(--transition);
  }
  .project-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .project-emoji { font-size: 2rem; display: block; margin-bottom: 0.5rem; }
  .project-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.4rem; }
  .project-card p { font-size: 0.88rem; color: var(--gray-500); margin-bottom: 0.75rem; line-height: 1.5; }
  .project-link { font-size: 0.88rem; font-weight: 600; }

  /* Instagram */
  .insta-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.75rem; max-width: 700px; margin: 0 auto; }
  .insta-card { display: flex; align-items: center; justify-content: center; aspect-ratio: 1; border-radius: var(--radius-lg); box-shadow: var(--shadow); transition: transform var(--transition); }
  .insta-card:hover { transform: translateY(-2px) scale(1.02); }

  /* CTA */
  .cta-box { text-align: center; max-width: 550px; margin: 0 auto; }
  .cta-box h2 { font-size: 1.4rem; margin-bottom: 0.6rem; }
  .cta-box p { color: var(--gray-500); margin-bottom: 1.25rem; }
  .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 640px) {
    .hero { padding: 3.5rem 1.25rem; }
    .insta-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
