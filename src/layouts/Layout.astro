---
export interface Props {
  title: string;
  description?: string;
  heroImage?: string;
  heroPosition?: string;
}

const { title, description, heroImage = '/images/cropped-header.jpg', heroPosition = 'center' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — Centro Sociocultural Zaidín</title>
    {description && <meta name="description" content={description} />}
    <style>
      /* ==========================================================================
         CSS Custom Properties
         ========================================================================== */
      :root {
        --teal-50: #ecfdf5;
        --teal-100: #d1fae5;
        --teal-200: #a7f3d0;
        --teal-300: #6ee7b7;
        --teal-400: #34d399;
        --teal-500: #10b981;
        --teal-600: #059669;
        --teal-700: #047857;
        --teal-800: #065f46;
        --teal-900: #064e3b;

        --warm-50: #fffbeb;
        --warm-100: #fef3c7;
        --warm-200: #fde68a;
        --warm-300: #fcd34d;
        --warm-400: #fbbf24;
        --warm-500: #f59e0b;
        --warm-600: #d97706;

        --rose-50: #fff1f2;
        --rose-100: #ffe4e6;
        --rose-200: #fecdd3;
        --rose-500: #f43f5e;
        --rose-600: #e11d48;

        --slate-50: #f8fafc;
        --slate-100: #f1f5f9;
        --slate-200: #e2e8f0;
        --slate-300: #cbd5e1;
        --slate-400: #94a3b8;
        --slate-500: #64748b;
        --slate-600: #475569;
        --slate-700: #334155;
        --slate-800: #1e293b;
        --slate-900: #0f172a;

        --bg: #ffffff;
        --bg-alt: var(--slate-50);
        --bg-card: #ffffff;
        --text: var(--slate-800);
        --text-muted: var(--slate-500);
        --text-light: var(--slate-400);
        --border: var(--slate-200);
        --radius: 12px;
        --radius-sm: 8px;
        --radius-lg: 16px;
        --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
        --shadow-md: 0 4px 6px rgba(0,0,0,0.05), 0 10px 15px rgba(0,0,0,0.05);
        --shadow-lg: 0 10px 25px rgba(0,0,0,0.08), 0 20px 40px rgba(0,0,0,0.04);
        --font: 'Inter', system-ui, -apple-system, sans-serif;
        --max-w: 1200px;
        --content-w: 760px;
        --nav-h: 68px;
        --transition: 200ms cubic-bezier(0.4, 0, 0.2, 1);
      }

      /* ==========================================================================
         Base
         ========================================================================== */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

      body {
        font-family: var(--font);
        font-size: 1.0625rem;
        line-height: 1.65;
        color: var(--text);
        background: var(--bg);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      img { max-width: 100%; height: auto; display: block; }
      a { color: var(--teal-700); text-decoration: none; transition: color var(--transition); }
      a:hover { color: var(--teal-600); }

      /* ==========================================================================
         Skip link
         ========================================================================== */
      .skip-link {
        position: absolute; top: -100%; left: 1rem;
        padding: 0.5rem 1rem;
        background: var(--teal-700); color: white;
        border-radius: 0 0 var(--radius-sm) var(--radius-sm);
        z-index: 1000;
        font-weight: 600; font-size: 0.9rem;
        transition: top var(--transition);
      }
      .skip-link:focus { top: 0; text-decoration: none; color: white; }

      /* ==========================================================================
         Navigation
         ========================================================================== */
      .nav {
        position: sticky; top: 0; z-index: 100;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
        height: var(--nav-h);
      }
      .nav-inner {
        max-width: var(--max-w); margin: 0 auto;
        display: flex; align-items: center; justify-content: space-between;
        height: 100%; padding: 0 1.5rem;
      }
      .nav-logo {
        display: flex; align-items: center; gap: 0.5rem;
        font-weight: 700; font-size: 1.05rem;
        color: var(--teal-700); text-decoration: none;
      }
      .nav-logo:hover { color: var(--teal-600); }
      .nav-logo .logo-dot {
        display: inline-block;
        width: 10px; height: 10px;
        border-radius: 50%;
        background: var(--teal-500);
      }

      .nav-toggle {
        display: none; flex-direction: column; gap: 5px;
        background: none; border: none; cursor: pointer;
        padding: 6px; z-index: 110; border-radius: var(--radius-sm);
      }
      .nav-toggle:hover { background: var(--slate-100); }
      .nav-toggle span {
        display: block; width: 24px; height: 2px;
        background: var(--text); border-radius: 2px;
        transition: transform 0.3s, opacity 0.3s;
      }
      .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
      .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      .nav-menu { display: flex; align-items: center; gap: 0; list-style: none; height: 100%; }
      .nav-item { position: relative; height: 100%; display: flex; align-items: center; }
      .nav-link {
        display: flex; align-items: center; height: 100%;
        padding: 0 1rem; color: var(--text);
        font-size: 0.9rem; font-weight: 500;
        text-decoration: none; white-space: nowrap;
        transition: color var(--transition);
      }
      .nav-link:hover, .nav-link.active { color: var(--teal-700); }
      .nav-link.active { box-shadow: inset 0 -2px 0 var(--teal-500); }
      .nav-link-dropdown { cursor: pointer; }
      .nav-link-dropdown::after {
        content: ''; display: inline-block;
        margin-left: 0.35rem;
        border-left: 4px solid transparent;
        border-right: 4px solid transparent;
        border-top: 5px solid currentColor;
        transition: transform 0.2s;
        vertical-align: middle;
      }
      .nav-item:hover .nav-link-dropdown::after { transform: rotate(180deg); }

      .dropdown {
        position: absolute; top: 100%; left: 0;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        box-shadow: var(--shadow-md);
        min-width: 220px;
        opacity: 0; visibility: hidden;
        transform: translateY(-4px);
        transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
        list-style: none; padding: 0.4rem 0; z-index: 200;
      }
      .nav-item:hover .dropdown,
      .nav-item:focus-within .dropdown {
        opacity: 1; visibility: visible; transform: translateY(0);
      }
      .dropdown-link {
        display: block; padding: 0.5rem 1.25rem;
        color: var(--text); font-size: 0.88rem;
        text-decoration: none; transition: background var(--transition), color var(--transition);
      }
      .dropdown-link:hover {
        background: var(--teal-50); color: var(--teal-700); text-decoration: none;
      }

      .nav-donate {
        margin-left: 0.75rem;
      }
      .btn-donate {
        display: inline-flex; align-items: center; gap: 0.35rem;
        padding: 0.45rem 1.1rem;
        background: var(--rose-500); color: white;
        border-radius: 999px; font-size: 0.85rem; font-weight: 600;
        transition: background var(--transition), transform var(--transition);
      }
      .btn-donate:hover { background: var(--rose-600); color: white; transform: translateY(-1px); }

      /* ==========================================================================
         Page hero
         ========================================================================== */
      .page-hero {
        position: relative;
        padding: 5rem 1.5rem 4rem;
        text-align: center;
        background: linear-gradient(135deg, var(--teal-800), var(--teal-600));
        overflow: hidden;
      }
      .page-hero::before {
        content: '';
        position: absolute; inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M20 0v40M0 20h40'/%3E%3C/g%3E%3C/svg%3E");
        z-index: 0;
      }
      .page-hero > * { position: relative; z-index: 1; }
      .page-hero h1 {
        color: white; font-size: clamp(1.8rem, 4vw, 2.6rem);
        font-weight: 800; line-height: 1.15;
        margin-bottom: 0.75rem;
      }
      .page-hero .subtitle {
        color: rgba(255,255,255,0.85);
        font-size: clamp(1rem, 2vw, 1.15rem);
        max-width: 600px; margin: 0 auto;
        line-height: 1.5;
      }

      /* ==========================================================================
         Page content
         ========================================================================== */
      .page-content {
        max-width: var(--content-w); margin: 0 auto;
        padding: 3rem 1.5rem 5rem;
      }
      .page-content-wide {
        max-width: var(--max-w); margin: 0 auto;
        padding: 3rem 1.5rem 5rem;
      }
      .page-content h2 {
        font-size: 1.5rem; color: var(--teal-700);
        margin-top: 3rem; margin-bottom: 1rem; font-weight: 700;
      }
      .page-content h2:first-child { margin-top: 0; }
      .page-content h3 {
        font-size: 1.15rem; color: var(--text);
        margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600;
      }
      .page-content p { margin-bottom: 1.2rem; }
      .page-content ul, .page-content ol {
        margin-bottom: 1.2rem; padding-left: 1.5rem;
      }
      .page-content li { margin-bottom: 0.4rem; }

      /* ==========================================================================
         Cards
         ========================================================================== */
      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem; margin: 2rem 0;
      }
      .card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.5rem;
        box-shadow: var(--shadow);
        transition: box-shadow var(--transition), transform var(--transition);
      }
      .card:hover {
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
      }

      /* ==========================================================================
         Buttons
         ========================================================================== */
      .btn {
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.65rem 1.4rem;
        border-radius: var(--radius-sm);
        font-weight: 600; font-size: 0.95rem; line-height: 1;
        border: none; cursor: pointer;
        text-decoration: none; transition: all var(--transition);
      }
      .btn:hover { transform: translateY(-1px); text-decoration: none; }
      .btn-primary { background: var(--teal-600); color: white; }
      .btn-primary:hover { background: var(--teal-700); color: white; }
      .btn-outline { border: 2px solid var(--teal-600); color: var(--teal-700); background: transparent; }
      .btn-outline:hover { background: var(--teal-50); }

      /* ==========================================================================
         Blockquote
         ========================================================================== */
      .page-content blockquote {
        border-left: 3px solid var(--teal-400);
        padding: 1rem 1.5rem; margin: 1.5rem 0;
        background: var(--teal-50);
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        font-style: italic; color: var(--slate-700);
      }
      .page-content blockquote cite {
        display: block; margin-top: 0.5rem;
        font-style: normal; font-weight: 600; color: var(--teal-700);
      }

      .highlight-box {
        background: var(--warm-50);
        border-left: 3px solid var(--warm-400);
        padding: 1.5rem;
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        margin: 1.5rem 0;
      }

      /* ==========================================================================
         Footer
         ========================================================================== */
      .footer {
        margin-top: auto;
        background: var(--slate-900);
        color: var(--slate-300);
        font-size: 0.95rem;
      }
      .footer-inner {
        max-width: var(--max-w); margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 3rem;
        padding: 4rem 1.5rem;
      }
      .footer h3 {
        color: white; font-size: 1rem; font-weight: 600;
        margin-bottom: 1rem;
        text-transform: uppercase; letter-spacing: 0.05em;
      }
      .footer p { line-height: 1.7; margin-bottom: 0.5rem; }
      .footer a { color: var(--teal-400); }
      .footer a:hover { color: var(--teal-300); }

      .footer-quote {
        font-style: italic; line-height: 1.7;
        border-left: 2px solid var(--teal-600);
        padding-left: 1rem;
      }
      .footer-quote cite {
        display: block; margin-top: 0.5rem;
        font-style: normal; color: var(--teal-400);
      }

      .footer-social {
        display: flex; gap: 0.75rem; margin-top: 1rem;
      }
      .footer-social a {
        display: flex; align-items: center; justify-content: center;
        width: 40px; height: 40px;
        border-radius: 50%;
        background: var(--slate-800); color: var(--slate-300);
        font-size: 1.2rem;
        transition: background var(--transition), color var(--transition);
      }
      .footer-social a:hover { background: var(--teal-700); color: white; }

      .footer-bottom {
        border-top: 1px solid var(--slate-800);
        padding: 1.5rem;
        text-align: center;
        font-size: 0.85rem;
        color: var(--slate-500);
      }
      .footer-bottom .tagline {
        color: var(--slate-400);
        letter-spacing: 0.1em;
        margin-top: 0.25rem;
      }

      .footer-links {
        list-style: none;
      }
      .footer-links li { margin-bottom: 0.5rem; }
      .footer-links a {
        color: var(--slate-300); font-size: 0.9rem;
      }
      .footer-links a:hover { color: white; }

      /* ==========================================================================
         Mobile
         ========================================================================== */
      @media (max-width: 768px) {
        .nav-toggle { display: flex; }
        .nav-menu {
          position: fixed; top: 0; right: -100%; width: 280px; height: 100vh;
          flex-direction: column; align-items: stretch;
          background: var(--bg); padding: 5rem 1rem 2rem;
          border-left: 1px solid var(--border);
          box-shadow: var(--shadow-lg);
          transition: right 0.3s ease; z-index: 100;
          overflow-y: auto;
        }
        .nav-menu.open { right: 0; }
        .nav-item { height: auto; flex-direction: column; }
        .nav-link { height: auto; padding: 0.75rem 1rem; }
        .nav-link.active { box-shadow: none; border-left: 3px solid var(--teal-500); }
        .dropdown {
          position: static; opacity: 1; visibility: visible;
          transform: none; box-shadow: none;
          border: none; padding-left: 1rem;
          max-height: 0; overflow: hidden;
          transition: max-height 0.3s ease;
          border-radius: 0;
        }
        .nav-item.open .dropdown { max-height: 400px; }
        .nav-link-dropdown::after { content: '▸'; border: none; font-size: 0.8rem; }
        .nav-item.open .nav-link-dropdown::after { transform: rotate(90deg); }
        .nav-donate { margin-left: 0; padding: 0.75rem 1rem; }
        .nav-donate .btn-donate { width: 100%; justify-content: center; }
        .nav-overlay {
          position: fixed; inset: 0; background: rgba(0,0,0,0.3);
          z-index: 99; opacity: 0; visibility: hidden;
          transition: opacity 0.3s, visibility 0.3s;
        }
        .nav-overlay.show { opacity: 1; visibility: visible; }

        .footer-inner {
          grid-template-columns: 1fr; gap: 2rem;
        }
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido</a>

    <nav class="nav" aria-label="Navegación principal">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <span class="logo-dot"></span>
          CSC Zaidín
        </a>

        <button class="nav-toggle" id="navToggle" aria-expanded="false" aria-label="Menú de navegación">
          <span></span><span></span><span></span>
        </button>

        <div class="nav-overlay" id="navOverlay"></div>

        <ul class="nav-menu" id="navMenu" role="menubar">
          <li class="nav-item" role="none">
            <a href="/" class="nav-link" role="menuitem">Inicio</a>
          </li>
          <li class="nav-item" role="none">
            <a href="/apoyo-a-la-regularizacion/" class="nav-link" role="menuitem">Regularización</a>
          </li>
          <li class="nav-item" role="none">
            <a href="/conocenos/" class="nav-link nav-link-dropdown" role="menuitem" aria-haspopup="true">Conócenos</a>
            <ul class="dropdown" role="menu" aria-label="Conócenos">
              <li role="none"><a href="/nuestra-historia/" class="dropdown-link" role="menuitem">Nuestra Historia</a></li>
